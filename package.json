{
  "name": "dot-pi",
  "private": true,
  "description": "Curated Pi extensions, skills, prompt shortcuts, and rules.",
  "keywords": [
    "pi-package"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dannote/dot-pi.git"
  },
  "type": "module",
  "scripts": {
    "check": "bun run lint && tsc --noEmit && bun run test:dupes",
    "format": "oxfmt .",
    "lint": "oxlint -c oxlint.json package.json extensions skills --ignore-pattern 'extensions/critic/tests/**' --deny-warnings",
    "format:check": "bash -lc 'oxfmt --check package.json $(find extensions skills -path \"*/node_modules\" -prune -o -name \"*.ts\" -print)'",
    "test": "bun test",
    "test:dupes": "jscpd --config .jscpd.json",
    "deps:check": "knip --config knip.json --reporter compact",
    "smoke:tutor": "expect demos/tapes/tutor-smoke.expect"
  },
  "dependencies": {
    "@anthropic-ai/sandbox-runtime": "^0.0.32",
    "cheerio": "^1.2.0",
    "cli-highlight": "^2.1.11",
    "diff": "^9.0.0",
    "glob": "^11.0.0",
    "jsonc-parser": "^3.3.1",
    "minimatch": "^10.2.5",
    "shell-quote": "^1.8.4",
    "turndown": "^7.2.0",
    "unpdf": "^1.4.0",
    "vscode-languageserver-types": "^3.17.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@earendil-works/pi-agent-core": "0.78.1",
    "@earendil-works/pi-ai": "0.78.1",
    "@earendil-works/pi-coding-agent": "0.78.1",
    "@earendil-works/pi-tui": "0.78.1",
    "@types/bun": "latest",
    "@types/shell-quote": "^1.7.5",
    "@types/turndown": "^5.0.6",
    "@types/ws": "^8.5.10",
    "jscpd": "^5.0.8",
    "knip": "^6.16.1",
    "oxfmt": "^0.24.0",
    "oxlint": "^1.42.0",
    "typebox": "^1.1.38",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "optionalDependencies": {
    "selection-hook": "^2.0.1"
  },
  "pi": {
    "extensions": [
      "extensions/ast-grep.ts",
      "extensions/background.ts",
      "extensions/choose-options.ts",
      "extensions/command-priority.ts",
      "extensions/codesearch.ts",
      "extensions/confirm-actions.ts",
      "extensions/context7",
      "extensions/env-json",
      "extensions/lsp",
      "extensions/notify.ts",
      "extensions/oracle.ts",
      "extensions/quote.ts",
      "extensions/question.ts",
      "extensions/refactor-discipline.ts",
      "extensions/workflow-shortcuts.ts",
      "extensions/webfetch",
      "extensions/websearch",
      "extensions/worktrees"
    ],
    "skills": [
      "skills/agent-browser",
      "skills/github-issues",
      "skills/keyboard-layout-decoder",
      "skills/skill-discovery"
    ],
    "prompts": [
      "prompts"
    ]
  },
  "trustedDependencies": [
    "selection-hook"
  ]
}
