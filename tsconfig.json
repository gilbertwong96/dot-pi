{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node"]
  },
  "include": ["extensions/**/*.ts", "skills/**/*.ts", "skills/**/*.d.ts"],
  "exclude": ["**/*.test.ts", "**/*.integration.ts", "skills/**/tests/**"]
}
